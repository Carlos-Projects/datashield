# DataShield Configuration
# Copy this file to .env and adjust values

# Confidence threshold for findings (0.0 = no filter, 0.5 = medium+, 0.8 = high+)
DATASHIELD_THRESHOLD=0.0

# Fields to exclude from scanning (comma-separated)
DATASHIELD_EXCLUDE_FIELDS=

# Default privacy budget for differential privacy
DATASHIELD_DEFAULT_EPSILON=1.0

# Default k value for k-anonymity
DATASHIELD_DEFAULT_K=5

# MCPscop webhook URL (optional)
DATASHIELD_MCPSCOP_URL=

# MCPscop API key (optional)
DATASHIELD_MCPSCOP_API_KEY=

# Enable debug mode
DATASHIELD_DEBUG=false

# Maximum input file size in MB (default: 500)
DATASHIELD_MAX_SIZE_MB=500
